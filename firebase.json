      },
      {
        "source": "/game-scores-admin",
        "destination": "/game-scores-admin.html"
      },
      {
        "source": "/api/workshop-events",
        "function": {
          "functionId": "publicWorkshopEvents",
          "region": "asia-east2"
        }
      },
      {
        "source": "**",
        "function": {
          "functionId": "resolvePageSlug",
          "region": "asia-east2"
        }
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(self), microphone=(), geolocation=()"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.gstatic.com https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://cdnjs.cloudflare.com https://cdn.sheetjs.com https://unpkg.com https://apis.google.com https://*.firebaseapp.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https: http: https://api.qrserver.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com https://r2cdn.perplexity.ai; media-src 'self' data: https://*.cloudfunctions.net; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com https://*.cloudfunctions.net https://*.run.app wss://*.firebaseio.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://www.gstatic.com https://cdn.jsdelivr.net https://script.google.com https://script.googleusercontent.com https://raw.githubusercontent.com; frame-src 'self' blob: data: https://accounts.google.com https://*.firebaseapp.com https://aiflowtime-hk.firebaseapp.com;"
          }
        ]
      },
      {
        "source": "/linktree",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "private, no-store, no-cache, max-age=0, must-revalidate"
          },
          {
            "key": "Pragma",
            "value": "no-cache"
