rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    function isValidFormSubmissionCreate() {
      return request.resource.data.keys().hasOnly([
          'formType',
          'sourceKey',
          'sourceLabel',
          'sourcePage',
          'sourcePath',
          'sourceUrl',
          'sourceCollection',
          'sourceDocId',
          'sheetTab',
          'importSource',
          'leadDefinitionId',
          'leadDefinitionType',
          'leadDefinitionName',
          'contactName',
          'phone',
          'whatsapp',
          'email',
          'instagram',
          'clientSubmittedAt',
          'submittedAt',
          'createdAt',
          'updatedAt',
          'answers',
          'searchText'
        ])
        && request.resource.data.formType is string
        && request.resource.data.formType in [
          'consultation',
          'workshop-waitlist',
          'lead-magnet',
          'quiz-lead',
          'free-material'
        ]
        && request.resource.data.importSource == 'live-form'
        && request.resource.data.answers is map
        && request.resource.data.clientSubmittedAt is string
        && request.resource.data.submittedAt is timestamp
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.searchText is string
        && (!request.resource.data.keys().hasAny(['sourceKey']) || request.resource.data.sourceKey is string)
        && (!request.resource.data.keys().hasAny(['sourceLabel']) || request.resource.data.sourceLabel is string)
        && (!request.resource.data.keys().hasAny(['sourcePage']) || request.resource.data.sourcePage is string)
        && (!request.resource.data.keys().hasAny(['sourcePath']) || request.resource.data.sourcePath is string)
        && (!request.resource.data.keys().hasAny(['sourceUrl']) || request.resource.data.sourceUrl is string)
        && (!request.resource.data.keys().hasAny(['sourceCollection']) || request.resource.data.sourceCollection is string)
        && (!request.resource.data.keys().hasAny(['sourceDocId']) || request.resource.data.sourceDocId is string)
        && (!request.resource.data.keys().hasAny(['sheetTab']) || request.resource.data.sheetTab is string)
        && (!request.resource.data.keys().hasAny(['leadDefinitionId']) || request.resource.data.leadDefinitionId is string)
        && (!request.resource.data.keys().hasAny(['leadDefinitionType']) || request.resource.data.leadDefinitionType is string)
        && (!request.resource.data.keys().hasAny(['leadDefinitionName']) || request.resource.data.leadDefinitionName is string)
        && (!request.resource.data.keys().hasAny(['contactName']) || request.resource.data.contactName is string)
        && (!request.resource.data.keys().hasAny(['phone']) || request.resource.data.phone is string)
        && (!request.resource.data.keys().hasAny(['whatsapp']) || request.resource.data.whatsapp is string)
        && (!request.resource.data.keys().hasAny(['email']) || request.resource.data.email is string)
        && (!request.resource.data.keys().hasAny(['instagram']) || request.resource.data.instagram is string);
    }

    // Workshops: public read; full write only for authorised CMS admins
    // Enrollment counting is now handled server-side via Cloud Functions
    match /workshops/{workshopId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Users / member profiles: owner can read/write own; admins can read all
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Registrations:
    //   - Anyone can create (guests + authenticated users)
    //   - Anyone can read a single document by ID (for shareable receipt links)
    //   - Authenticated users can read own registrations
    //   - Admins can read/write all
    match /registrations/{regId} {
      allow create: if true;
      allow get: if true;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update: if (
          (request.auth != null && resource.data.userId == request.auth.uid) ||
          (request.auth == null && resource.data.userId == null)
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'paymentScreenshotUrl',
          'name', 'ageGroup', 'phone', 'jobType', 'reasons',
          'aiProblem', 'expectation',
          'workshopTitle', 'workshopDate', 'workshopTime', 'workshopDescription',
          'allSessionDates', 'selectedRound', 'selectedRoundLabel',
          'pricePaid', 'discountApplied', 'promoCode',
          'updatedAt'
        ]);
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Discount codes: public read (payment page needs to check); admin write
    match /discountCodes/{codeId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Quiz leads: anyone can create; only admins can read
    match /quizLeads/{leadId} {
      allow create: if true;
      allow read: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Unified forms inbox: public create for allowed lead fields; admin manages inbox metadata
    match /formSubmissions/{docId} {
      allow create: if isValidFormSubmissionCreate();
      allow read, update, delete: if isAdmin();
    }

    match /leadDefinitions/{docId} {
      allow read: if isAdmin()
        || (
          resource.data.publicEnabled == true
          && resource.data.status == 'active'
        );
      allow create, update, delete: if isAdmin();
    }

    // Reservations: backend only (Functions use Admin SDK)
    match /reservations/{reservationId} {
      allow read, write: if false;
    }

    // Business projects: admin only
    match /projects/{projectId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Business documents: public read (for shareable PDF links), admin write
    match /businessDocuments/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Business settings: admin only
    match /businessSettings/{settingId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Workshop settings: admin only
    match /workshopSettings/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // CMS settings: admin only
    match /cmsSettings/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Page layouts: public read (workshop page applies layout), admin write
    match /pageLayouts/{layoutId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Section presets: admin only
    match /sectionPresets/{presetId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // QR feedback submissions: anyone can create; only jacobfung1392 can read (for display page)
    match /qrSubmissions/{subId} {
      allow create: if true;
      allow read: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'jacobfung1392@gmail.com';
      allow update, delete: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'jacobfung1392@gmail.com';
    }

    // QR form settings: public read (submit page shows titles); only jacobfung1392 can write
    match /qrSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'jacobfung1392@gmail.com';
    }

    // Consultation applications: anyone can create; admin read/write
    match /consultations/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Consultation settings: admin only
    match /consultationSettings/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Game scores: anyone can create (submit from game); public read; admin update/delete
    match /gameScores/{scoreId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Floating icon reusable assets: public read (linktree renders them), admin write
    match /floatingIconAssets/{assetId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // AI Tools: public read (landing pages render tool labels), admin write
    match /aiTools/{toolId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Site-wide transactional email headers (Trigger Email extension reads `mail` docs; from/replyTo set client-side from this doc)
    match /siteSettings/{docId} {
      allow read: if docId == 'emailOutbound';
      allow write: if docId == 'emailOutbound' && isAdmin();
    }

    // Free-material download leads: anyone can create; admin read
    match /freeMaterialLeads/{leadId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Pending WhatsApp outreach (Meta integration TBD): visitors may enqueue; admin only read/update
    match /whatsappOutreachQueue/{entryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Trigger Email extension: anyone can create a mail doc; admin read
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Layout document library assets: admin only
    match /layoutDocumentAssets/{assetId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Layout document folders: admin only
    match /layoutDocumentFolders/{folderId} {
      allow read, write: if request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'jacobfung1392@gmail.com',
          'jacobfung@aiflowtime.com'
        ];
    }

    // Carousel Builder cloud projects (distinct from /projects business docs): admin only
    match /carouselProjects/{projectId} {
      allow read, write: if isAdmin();
    }
  }
}
